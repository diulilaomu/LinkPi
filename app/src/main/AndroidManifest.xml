<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:usesCleartextTraffic="false"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Linkpi">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustNothing"
            android:theme="@style/Theme.Linkpi">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SSH standalone activity — independent recents card -->
        <activity
            android:name=".SshActivity"
            android:taskAffinity="com.example.link_pi.ssh"
            android:autoRemoveFromRecents="false"
            android:resizeableActivity="true"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Linkpi" />

        <!-- MiniApp base activity -->
        <activity
            android:name=".MiniAppActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Linkpi" />

        <!-- Concrete task-slot Activities with distinct taskAffinity for task isolation. -->
        <activity android:name=".MiniAppSlot0"
            android:taskAffinity="com.example.link_pi.slot0"
            android:autoRemoveFromRecents="false"
            android:resizeableActivity="true"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Linkpi" />
        <activity android:name=".MiniAppSlot1"
            android:taskAffinity="com.example.link_pi.slot1"
            android:autoRemoveFromRecents="false"
            android:resizeableActivity="true"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Linkpi" />
        <activity android:name=".MiniAppSlot2"
            android:taskAffinity="com.example.link_pi.slot2"
            android:autoRemoveFromRecents="false"
            android:resizeableActivity="true"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Linkpi" />
        <activity android:name=".MiniAppSlot3"
            android:taskAffinity="com.example.link_pi.slot3"
            android:autoRemoveFromRecents="false"
            android:resizeableActivity="true"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Linkpi" />
        <activity android:name=".MiniAppSlot4"
            android:taskAffinity="com.example.link_pi.slot4"
            android:autoRemoveFromRecents="false"
            android:resizeableActivity="true"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Linkpi" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <service
            android:name=".workbench.GenerationService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <service
            android:name=".ui.ssh.KeepAliveService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />
    </application>

</manifest>